# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# ═════════════════════════════════════════════════════════════════════════════
# Salesforce
# ═════════════════════════════════════════════════════════════════════════════

# Local dev: paste your sandbox session token (sf org display --target-org <alias>)
SALESFORCE_ACCESS_TOKEN=
SALESFORCE_INSTANCE_URL=https://your-org.my.salesforce.com

# Production / staging: use Connected App Client Credentials flow instead.
# Set these in Netlify env (NOT here for local dev).
# SALESFORCE_CLIENT_ID=
# SALESFORCE_CLIENT_SECRET=
# SALESFORCE_TOKEN_URL=https://login.salesforce.com/services/oauth2/token

# ──── Portal-only Salesforce identity (Stage 1 hardening, 2026-05-11) ────
# Separate Connected App authenticating as a dedicated integration user
# assigned ONLY the Portal_Integration_User_PS perm set. If portal tokens
# leak, blast radius is the portal-relevant objects only — no email send,
# no lead conversion, no broader CRM access. See:
#   docs/portal-stage-1-dedicated-integration-user.md
# Falls back to the general identity if not set (transitional only — set
# these on Netlify ASAP to complete Stage 1).
# SALESFORCE_PORTAL_CLIENT_ID=
# SALESFORCE_PORTAL_CLIENT_SECRET=

# ──── Portal Apex JWT signing (Stage 2 hardening, 2026-05-11) ────────────
# HMAC-SHA256 secret shared with Salesforce via Portal_Auth_Setting__mdt.
# Every portal Apex call (except /Portal/access pre-auth lookup) signs a
# 60s JWT carrying accountId. Apex verifies the signature and uses the
# JWT-derived accountId for SOQL, ignoring URL params. Closes audit
# finding #4 — IDOR via URL-param spoofing is structurally impossible
# even with a leaked Bearer token.
#
# Generate: `openssl rand -base64 48` — 32+ random bytes URL-safe.
# Same value MUST be set in:
#   1. Netlify env var PORTAL_APEX_JWT_SECRET (per deploy context)
#   2. Salesforce Setup → Custom Metadata Types → Portal Auth Setting
#      → Manage Records → HMAC v1 → edit HMAC Secret field
# See: docs/portal-stage-2-apex-jwt-verification.md
# PORTAL_APEX_JWT_SECRET=
# Optional — override the kid (key id) when rotating. Defaults to HMAC_v1.
# PORTAL_APEX_JWT_KID=HMAC_v1

# ──── Portal sync webhook HMAC (Stage 3 hardening, 2026-05-11) ────────────
# Shared secret verifying inbound SF → Next.js callouts at /api/portal/sync.
# Same value must be set in:
#   1. This Netlify env var
#   2. Salesforce Portal_Auth_Setting__mdt 'HMAC v1' → Sync_HMAC_Secret__c
# Deliberately distinct from PORTAL_APEX_JWT_SECRET (different direction,
# different threat model). Generate via `openssl rand -base64 48`.
# Salesforce side ALSO needs Sync_Webhook_URL__c populated with this
# environment's branch-deploy / production URL of /api/portal/sync.
# PORTAL_SYNC_HMAC_SECRET=

# ═════════════════════════════════════════════════════════════════════════════
# Client Portal — Clerk (auth)
# https://dashboard.clerk.com → API Keys
# ═════════════════════════════════════════════════════════════════════════════

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxx
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxx

# Portal sign-in/up URL paths
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/portal/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/portal/sign-up

# ═════════════════════════════════════════════════════════════════════════════
# Client Portal — Supabase (Postgres read cache for portal data)
# https://supabase.com/dashboard → Project Settings → API
# ═════════════════════════════════════════════════════════════════════════════

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxx
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxx

# Direct DB URL for Drizzle migrations (use the pooled connection string)
SUPABASE_DB_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# ═════════════════════════════════════════════════════════════════════════════
# Client Portal — Sync + Rate limiting + Calendly
# (set these once integrations are live)
# ═════════════════════════════════════════════════════════════════════════════

# HMAC secret for verifying SF Platform Event webhook payloads at /api/portal/sync
PORTAL_SYNC_HMAC_SECRET=

# Upstash Redis (rate limiting + hot caching). The code accepts either
# the *_REST_* names (Upstash's canonical) OR the shorter legacy names —
# both work. Set ONE pair on Netlify.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# (Legacy alternative names — still work)
# UPSTASH_REDIS_URL=
# UPSTASH_REDIS_TOKEN=

# Calendly webhook signing secret (verifies invitee.created callbacks)
CALENDLY_WEBHOOK_SECRET=

# ═════════════════════════════════════════════════════════════════════════════
# Dev-only overrides
# ═════════════════════════════════════════════════════════════════════════════

# Pin the dashboard to a specific Salesforce Account id for local development.
# Removed once the Clerk↔SF link table lands (Track A) and we resolve the
# real account from the signed-in user's verified email.
PORTAL_DEV_ACCOUNT_ID=
