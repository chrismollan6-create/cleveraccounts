# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# ═════════════════════════════════════════════════════════════════════════════
# Salesforce
# ═════════════════════════════════════════════════════════════════════════════

# Local dev: paste your sandbox session token (sf org display --target-org <alias>)
SALESFORCE_ACCESS_TOKEN=
SALESFORCE_INSTANCE_URL=https://your-org.my.salesforce.com

# Production / staging: use Connected App Client Credentials flow instead.
# Set these in Netlify env (NOT here for local dev).
# SALESFORCE_CLIENT_ID=
# SALESFORCE_CLIENT_SECRET=
# SALESFORCE_TOKEN_URL=https://login.salesforce.com/services/oauth2/token

# ═════════════════════════════════════════════════════════════════════════════
# Client Portal — Clerk (auth)
# https://dashboard.clerk.com → API Keys
# ═════════════════════════════════════════════════════════════════════════════

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxx
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxx

# Portal sign-in/up URL paths
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/portal/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/portal/sign-up

# ═════════════════════════════════════════════════════════════════════════════
# Client Portal — Supabase (Postgres read cache for portal data)
# https://supabase.com/dashboard → Project Settings → API
# ═════════════════════════════════════════════════════════════════════════════

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxx
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxx

# Direct DB URL for Drizzle migrations (use the pooled connection string)
SUPABASE_DB_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# ═════════════════════════════════════════════════════════════════════════════
# Client Portal — Sync + Rate limiting + Calendly
# (set these once integrations are live)
# ═════════════════════════════════════════════════════════════════════════════

# HMAC secret for verifying SF Platform Event webhook payloads at /api/portal/sync
PORTAL_SYNC_HMAC_SECRET=

# Upstash Redis (rate limiting + hot caching)
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# Calendly webhook signing secret (verifies invitee.created callbacks)
CALENDLY_WEBHOOK_SECRET=

# ═════════════════════════════════════════════════════════════════════════════
# Dev-only overrides
# ═════════════════════════════════════════════════════════════════════════════

# Pin the dashboard to a specific Salesforce Account id for local development.
# Removed once the Clerk↔SF link table lands (Track A) and we resolve the
# real account from the signed-in user's verified email.
PORTAL_DEV_ACCOUNT_ID=
